# App
APP_NAME=SueldoYa API
APP_VERSION=2.0.0
DEBUG=false

# Database (Railway te da DATABASE_URL automáticamente)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app_sueldo
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/app_sueldo

# JWT — CAMBIAR EN PRODUCCIÓN
JWT_SECRET=cambiar-esto-por-un-secreto-seguro-en-produccion
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:3000"]
